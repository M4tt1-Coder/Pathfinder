{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "rust: fmt-check",
			"type": "shell",
			"command": "cargo",
			"args": [
				"fmt",
				"--all",
				"--",
				"--check"
			],
			"isBackground": false
		},
		{
			"label": "rust: clippy-strict",
			"type": "shell",
			"command": "cargo",
			"args": [
				"clippy",
				"--all-targets",
				"--all-features",
				"--",
				"-D",
				"warnings"
			],
			"isBackground": false
		},
		{
			"label": "rust: test-all-targets",
			"type": "shell",
			"command": "cargo",
			"args": [
				"test",
				"--workspace",
				"--all-targets",
				"--locked"
			],
			"isBackground": false
		},
		{
			"label": "rust: test-docs",
			"type": "shell",
			"command": "cargo",
			"args": [
				"test",
				"--workspace",
				"--doc",
				"--locked"
			],
			"isBackground": false
		},
		{
			"label": "git-add-test-suite-changes",
			"type": "shell",
			"command": "git",
			"args": [
				"add",
				".github/workflows/rust-ci.yml",
				".github/workflows/rust.yml",
				".vscode/tasks.json",
				"Cargo.toml",
				"Cargo.lock",
				"tests",
				"diary/feature/a_star/020-add-production-grade-test-suite-and-ci-hardening.md"
			],
			"isBackground": false
		},
		{
			"label": "git-status-short",
			"type": "shell",
			"command": "git",
			"args": [
				"status",
				"--short"
			],
			"isBackground": false
		},
		{
			"label": "git-add-instructions-update",
			"type": "shell",
			"command": "git",
			"args": [
				"add",
				".github/copilot-instructions.md",
				"diary/feature/a_star/021-add-readme-synchronization-rule-to-instructions.md"
			],
			"isBackground": false
		},
		{
			"label": "git-commit-instructions-update",
			"type": "shell",
			"command": "git",
			"args": [
				"commit",
				"-m",
				"Require README synchronization check in repo instructions"
			],
			"isBackground": false
		},
		{
			"label": "git-status-short",
			"type": "shell",
			"command": "git",
			"args": [
				"status",
				"--short"
			],
			"isBackground": false
		},
		{
			"label": "git-status-short",
			"type": "shell",
			"command": "git",
			"args": [
				"status",
				"--short"
			],
			"isBackground": false
		},
		{
			"label": "git-diff-stat",
			"type": "shell",
			"command": "git",
			"args": [
				"diff",
				"--stat"
			],
			"isBackground": false
		},
		{
			"label": "git-diff",
			"type": "shell",
			"command": "git",
			"args": [
				"--no-pager",
				"diff"
			],
			"isBackground": false
		},
		{
			"label": "git-add-all-unstaged-plus-diary",
			"type": "shell",
			"command": "git",
			"args": [
				"add",
				".vscode/tasks.json",
				"src/main.rs",
				"diary/feature/a_star/022-commit-all-current-unstaged-changes.md"
			],
			"isBackground": false
		}
	]
}